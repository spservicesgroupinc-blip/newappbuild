# ============================================================
# SUPABASE ENVIRONMENT CONFIGURATION
# Spray Foam Insulation Business Management Tool
# ============================================================

# Copy this file to .env and fill in your Supabase credentials
# DO NOT commit .env to version control

# ============================================================
# SUPABASE CREDENTIALS
# Get these from: https://app.supabase.com/project/_/settings/api
# ============================================================

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=

# Your Supabase anon/public key (safe for client-side use)
# DO NOT use the service role key in client-side code
VITE_SUPABASE_ANON_KEY=

# ============================================================
# OPTIONAL: SUPABASE SERVICE ROLE KEY
# Only for server-side/Edge Function use
# NEVER expose this in client-side code
# ============================================================

# SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# OPTIONAL: GOOGLE API CREDENTIALS (for Work Order Sheet creation)
# If you want to continue creating Google Sheets for work orders
# ============================================================

# GOOGLE_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ============================================================
# OPTIONAL: EMAIL CONFIGURATION
# For custom email templates via Supabase Email API
# ============================================================

# SUPABASE_SMTP_HOST=
# SUPABASE_SMTP_PORT=
# SUPABASE_SMTP_USER=
# SUPABASE_SMTP_PASSWORD=

# ============================================================
# APP CONFIGURATION
# ============================================================

# App name
VITE_APP_NAME=RFE Foam Pro

# Enable/disable features
VITE_ENABLE_CREW_LOGIN=true
VITE_ENABLE_TRIAL_MODE=true

# Trial period in days
VITE_TRIAL_PERIOD_DAYS=14

# ============================================================
# STORAGE CONFIGURATION
# ============================================================

# Maximum file size for uploads (in bytes)
VITE_MAX_FILE_SIZE=52428800

# Allowed image types
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/jpg,image/png,image/webp

# ============================================================
# DEVELOPMENT SETTINGS
# ============================================================

# Enable debug logging
VITE_DEBUG=false

# Enable React DevTools
VITE_REACT_DEVTOOLS=true

# ============================================================
# MIGRATION SETTINGS (for Google Apps Script migration)
# ============================================================

# Legacy Google Script URL (for data migration)
# VITE_GOOGLE_SCRIPT_URL=

# Enable migration mode
VITE_MIGRATION_MODE=false
